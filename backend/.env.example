MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/libraryApp?appName=Cluster0
PORT=5000
JWT_SECRET=replace_with_a_long_random_string_at_least_32_chars
JWT_EXPIRES_IN=7d

# ── URLs ──────────────────────────────────────────────────────────
# No trailing slash on any URL — CORS origin matching is exact.
CLIENT_URL=https://your-frontend.vercel.app
FRONTEND_URL=https://your-frontend.vercel.app
SERVER_URL=https://your-backend.onrender.com

# ── Email / SMTP ──────────────────────────────────────────────────
# Gmail: enable 2-Step Verification → Google Account → Security → App Passwords
# Use the 16-char App Password (not your Gmail login password).
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
